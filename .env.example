# 文渊机器人项目环境变量配置
# 复制此文件为 .env 并填写实际值

# ==================== OpenAI API 配置 ====================
# OpenAI API密钥（必填）
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI API地址（可选，使用代理时填写）
# 直连: https://api.openai.com/v1
# 代理示例: https://api.gptapi.us/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# ==================== 边缘服务器配置 ====================
# chatbot2024 API地址（Docker内部使用服务名）
CHATIE_API_URL=http://chatbot:1090/chatbot/api/v1.0/get

# 聊天配置名称
CHAT_CONF_NAME=default

# 是否启用语音功能（Docker中建议禁用）
VOICE_EN=false

# 机器人底盘类型 (SMART 或 AGILEX)
BOT_TYPE=SMART